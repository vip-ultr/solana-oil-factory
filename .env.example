# Copy to .env.local and fill in. NEVER commit .env.local — it's
# gitignored. For Vercel set the same NEXT_PUBLIC_* vars in the
# project's Environment Variables tab.

# ============================================================
# Helius — Solana RPC + indexed APIs
# ============================================================
# Server-only. Used by lib/helius.ts and the /api/rpc proxy when
# NEXT_PUBLIC_SOLANA_RPC_URL is unset (mainnet path).
HELIUS_API_KEY=

# ============================================================
# Solana RPC + WebSocket — devnet for current dev cycle
# ============================================================
# When unset, the browser routes RPC through /api/rpc (which
# proxies to Helius). Setting this overrides that and hits the
# RPC directly — only safe for unauthenticated endpoints.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_WS_URL=wss://api.devnet.solana.com/

# ============================================================
# Refinery program — deployed Anchor program
# ============================================================
# Program ID is stable across clusters (we control the keypair).
# Treasury authority = deployer key, used as snapshot/pause
# authority + SOL fee receiver in v1.
NEXT_PUBLIC_REFINERY_PROGRAM_ID=2tPLLPQeLLNL4UDBbeagSUAABJcB3fHGTJaLGEzrx3rE
NEXT_PUBLIC_TREASURY_AUTHORITY=57CY8LCq65ahQqouXtPUqGx1B8qgQeg3VjEgt9tQAqsV

# ============================================================
# Supabase — primary data store
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================
# Bags — launchpad API (refinery source)
# ============================================================
BAGS_API_KEY=

# ============================================================
# Optional production hardening
# ============================================================
# Additional origins allowed to hit /api/rpc in production.
# RPC_ALLOWED_ORIGINS=https://staging.solanaoilfactory.xyz
